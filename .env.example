# Spotify Client ID for OAuth PKCE flow
# Create a Spotify app at https://developer.spotify.com/dashboard
# Set the Redirect URI to your deployed app URL (e.g. https://your-app.vercel.app/)
# Copy the Client ID here
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here

# Vercel Blob token for persistent state sharing
# This is automatically set when you link a Blob Store in Vercel Dashboard:
# Project Settings → Storage → Create → Blob Store
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token_here
